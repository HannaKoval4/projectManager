<UserControl x:Class="ProjectManager.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Фильтры по времени -->
        <Border Grid.Row="0" 
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,20"
                Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Период: " 
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"/>
                <Button Content="Месяц" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="Month"/>
                <Button Content="Квартал" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="Quarter"/>
                <Button Content="Год" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding FilterByPeriodCommand}"
                        CommandParameter="Year"/>
            </StackPanel>
        </Border>
        
        <!-- Статистические карточки -->
        <UniformGrid Grid.Row="1" 
                     Columns="4" 
                     Margin="0,0,0,20">
            <Border Style="{StaticResource CardStyle}" Margin="5">
                <StackPanel>
                    <TextBlock Text="Всего проектов" 
                               Foreground="#7F8C8D"
                               FontSize="12"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalProjects}" 
                               Style="{StaticResource HeadingText}"
                               Foreground="{StaticResource AccentBlueBrush}"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardStyle}" Margin="5">
                <StackPanel>
                    <TextBlock Text="Завершенных задач" 
                               Foreground="#7F8C8D"
                               FontSize="12"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CompletedTasks}" 
                               Style="{StaticResource HeadingText}"
                               Foreground="#27AE60"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardStyle}" Margin="5">
                <StackPanel>
                    <TextBlock Text="Активных задач" 
                               Foreground="#7F8C8D"
                               FontSize="12"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding ActiveTasks}" 
                               Style="{StaticResource HeadingText}"
                               Foreground="#F39C12"/>
                </StackPanel>
            </Border>
            
            <Border Style="{StaticResource CardStyle}" Margin="5">
                <StackPanel>
                    <TextBlock Text="Сотрудников" 
                               Foreground="#7F8C8D"
                               FontSize="12"
                               Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TotalEmployees}" 
                               Style="{StaticResource HeadingText}"
                               Foreground="{StaticResource GraphiteBrush}"/>
                </StackPanel>
            </Border>
        </UniformGrid>
        
        <!-- Таблица продуктивности -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" 
                           Text="Рейтинг продуктивности сотрудников" 
                           Style="{StaticResource SubHeadingText}"
                           Margin="0,0,0,15"/>
                
                <DataGrid Grid.Row="1" 
                          ItemsSource="{Binding EmployeeStatistics}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          Background="White"
                          BorderBrush="#E0E0E0"
                          BorderThickness="1"
                          RowBackground="White"
                          AlternatingRowBackground="#F9F9F9">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeName}" Width="*"/>
                        <DataGridTextColumn Header="Завершено задач" Binding="{Binding CompletedTasks}" Width="150"/>
                        <DataGridTextColumn Header="Активных задач" Binding="{Binding ActiveTasks}" Width="150"/>
                        <DataGridTemplateColumn Header="Продуктивность" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ProgressBar Value="{Binding Productivity}" 
                                                 Maximum="100"
                                                 Height="20"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>





