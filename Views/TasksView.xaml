<UserControl x:Class="ProjectManager.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ProjectManager.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <local:PriorityToColorConverter x:Key="PriorityToColorConverter"/>
        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>
    </UserControl.Resources>
    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskCommand}"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding EditTaskCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding CompleteTaskCommand}"/>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding ResetFiltersCommand}"/>
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Панель управления -->
        <Border Grid.Row="0" 
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,20"
                Padding="15">
            <StackPanel Orientation="Horizontal">
                <Button Content="Добавить задачу (Ctrl+N)" 
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding AddTaskCommand}"/>
                <Button Content="Изменить (Ctrl+E)" 
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding EditTaskCommand}"/>
                <Button Content="Завершить (Del)" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding CompleteTaskCommand}"/>
                <Button Content="Сбросить фильтры (Ctrl+F)" 
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ResetFiltersCommand}"
                        Margin="20,0,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Панель фильтров -->
        <Border Grid.Row="1" 
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,20"
                Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Проект" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Projects}" 
                              SelectedItem="{Binding SelectedProjectFilter}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="ID"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                    <TextBlock Text="Статус" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Statuses}" 
                              SelectedItem="{Binding SelectedStatusFilter}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Margin="10,0,10,0">
                    <TextBlock Text="Приоритет" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Priorities}" 
                              SelectedItem="{Binding SelectedPriorityFilter}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="3" Margin="10,0,0,0">
                    <TextBlock Text="Исполнитель" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Employees}" 
                              SelectedItem="{Binding SelectedEmployeeFilter}"
                              DisplayMemberPath="FullName"
                              SelectedValuePath="ID"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Список задач -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" 
                                Margin="0,0,0,15"
                                MouseLeftButtonDown="TaskCard_MouseLeftButtonDown"
                                Cursor="Hand"
                                ContextMenuOpening="TaskCard_ContextMenuOpening">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Изменить (Ctrl+E)" Command="{Binding DataContext.EditTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <MenuItem Header="Завершить (Del)" Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Separator/>
                                    <MenuItem Header="Быстрая смена статуса">
                                        <MenuItem Header="В работу" Click="QuickStatusChange_Click" Tag="В работе"/>
                                        <MenuItem Header="На проверке" Click="QuickStatusChange_Click" Tag="На проверке"/>
                                        <MenuItem Header="Завершена" Click="QuickStatusChange_Click" Tag="Завершена"/>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" 
                                           Grid.Column="0"
                                           Text="{Binding Title}" 
                                           Style="{StaticResource SubHeadingText}"
                                           Margin="0,0,0,10"/>
                                
                                <StackPanel Grid.Row="1" 
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,10">
                                    <Border Background="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}" 
                                            CornerRadius="4"
                                            Padding="8,4"
                                            Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Priority}" 
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" 
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <TextBlock Text="{Binding Status}" 
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="2" 
                                            Grid.Column="0"
                                            Orientation="Horizontal">
                                    <TextBlock Text="Проект: " 
                                               Foreground="#7F8C8D"
                                               FontSize="12"/>
                                    <TextBlock Text="{Binding Project.Name}" 
                                               Foreground="{StaticResource AccentBlueBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text=" | Исполнитель: " 
                                               Foreground="#7F8C8D"
                                               FontSize="12"
                                               Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding Employee.FullName, FallbackValue='Не назначен'}" 
                                               Foreground="{StaticResource AccentBlueBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
